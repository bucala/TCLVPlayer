{
  "name": "tclvplayer",
  "version": "1.1.12",
  "private": true,
  "description": "Simple IPTV player for Windows, Android, GoogleTV and web.",
  "main": "native/electron/main.js",
  "scripts": {
    "prepare:web": "node scripts/copy-web.mjs",
    "web": "npx http-server . -p 3000 -c-1",
    "proxy": "node scripts/local-proxy.mjs",
    "windows": "npm run prepare:web && electron .",
    "windows:dist": "npm run prepare:web && electron-builder --win nsis portable --publish never",
    "android:init": "node scripts/ensure-android-project.mjs",
    "android:apply-template": "node scripts/apply-android-template.mjs",
    "android:setup": "npm run prepare:web && npm run android:init && npm run android:apply-template && cap sync android",
    "android:sync": "npm run prepare:web && npm run android:init && npm run android:apply-template && cap sync android",
    "android:generate": "node scripts/android-studio.mjs",
    "android:studio": "node scripts/android-studio.mjs --open",
    "android:apk": "node scripts/android-studio.mjs --build",
    "android:open": "cap open android",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "build": {
    "appId": "sk.tclv.player",
    "productName": "TCLVPlayer",
    "files": [
      "dist/web/**/*",
      "assets/icon.png",
      "native/electron/**/*"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "asar": true
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "artplayer": "^5.2.5",
    "flv.js": "^1.6.2",
    "hls.js": "^1.5.20",
    "jplayer": "^2.9.2",
    "jquery": "^3.7.1",
    "mpegts.js": "^1.8.0",
    "video.js": "^8.21.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^10.0.1",
    "electron": "^42.4.0",
    "electron-builder": "^26.15.3",
    "eslint": "^10.4.1",
    "http-server": "^14.1.1",
    "vitest": "^4.1.8"
  }
}
