{
  "name": "tclvplayer",
  "version": "1.0.0",
  "private": true,
  "description": "Simple IPTV player for Windows, Android, GoogleTV and web.",
  "main": "native/electron/main.js",
  "scripts": {
    "prepare:web": "node scripts/copy-web.mjs",
    "web": "npx http-server . -p 3000 -c-1",
    "proxy": "node scripts/local-proxy.mjs",
    "windows": "npm run prepare:web && electron .",
    "windows:dist": "npm run prepare:web && electron-builder --win nsis portable --publish never",
    "android:init": "cap add android",
    "android:apply-template": "node scripts/apply-android-template.mjs",
    "android:setup": "npm run prepare:web && cap add android && npm run android:apply-template && cap sync android",
    "android:sync": "npm run prepare:web && npm run android:apply-template && cap sync android",
    "android:open": "cap open android",
    "lint": "eslint .",
    "test": "vitest run"
  },
  "build": {
    "appId": "sk.tclv.player",
    "productName": "TCLVPlayer",
    "files": [
      "index.html",
      "styles.css",
      "app.js",
      "favicon.svg",
      "dist/web/**/*",
      "assets/**/*",
      "native/electron/**/*",
      "node_modules/video.js/dist/**/*",
      "node_modules/artplayer/dist/**/*",
      "node_modules/hls.js/dist/**/*",
      "node_modules/mpegts.js/dist/**/*"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "assets/icon.png"
    }
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "artplayer": "^5.2.5",
    "hls.js": "^1.5.20",
    "mpegts.js": "^1.8.0",
    "video.js": "^8.21.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.3.4",
    "@eslint/js": "^10.0.1",
    "electron": "^42.3.0",
    "electron-builder": "^26.0.0",
    "eslint": "^10.4.1",
    "http-server": "^14.1.1",
    "vitest": "^4.1.7"
  }
}
