<!-- Merge these entries into android/app/src/main/AndroidManifest.xml after `npm run android:init`. -->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">
  <uses-permission android:name="android.permission.INTERNET" />
  <uses-feature android:name="android.software.leanback" android:required="false" />
  <uses-feature android:name="android.hardware.touchscreen" android:required="false" />

  <application android:banner="@mipmap/ic_launcher">
    <!-- Add to the MainActivity intent-filter so TCLVPlayer appears on GoogleTV launchers. -->
    <category android:name="android.intent.category.LEANBACK_LAUNCHER" />
  </application>
</manifest>
